# Django Production Settings
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=replace-with-a-long-random-secret-key-min-50-chars
DJANGO_ALLOWED_HOSTS=yourapp.onrender.com,yourdomain.com,www.yourdomain.com
DJANGO_CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_CORS_ALLOW_ALL_ORIGINS=False

# Database (Render will provide this automatically)
DATABASE_URL=postgres://user:password@host:5432/database

# Redis Cache (Render provides this automatically on paid plans, optional on free)
REDIS_URL=redis://host:6379/1
USE_LOCAL_CACHE=False

# Optional: Email settings (for password reset, etc.)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
